<pretext xmlns:xi="http://www.w3.org/2001/XInclude" xml:lang="en-US">

<xi:include href="./bookinfo.ptx" />

<book xml:id="calculus-concepts-modelling-book">
<title>Calculus Concepts and Modelling</title>
<subtitle>An introduction to the concepts of calculus</subtitle>

<!-- -->
<xi:include href="./frontmatter.ptx" />

<!-- Variables, constants, and parameters. Change and variation. -->
<xi:include href="./vars.ptx" />

<!-- Functions, accumulation, and rate of variation. Graphs of functions. Transformations of functions/graphs. -->
<xi:include href="./funcs.ptx" />

<!-- Modelling accumulation and rate of variation. Differential equation examples (but no solving). -->
<xi:include href="./models.ptx" />

<!--
  Long-term behaviour: horizontal asymptotes (i.e., informal treatment of limits as x → ∞).
  Singular behaviour: vertical asymptotes (i.e., informal treatment of limits where y →∞).
  Connections to differential equations.
-->
<xi:include href="./inf-behaviour.ptx" />

<xi:include href="./step.ptx" />

<!--
  Approximate accumulation from rate of variation (using step functions).
  Exact accumulation from rate of variation.
-->
<xi:include href="./integ.ptx" />

<!-- Polynomial growth (i.e., accumulation when rate of variation is polynomial). -->
<xi:include href="./poly.ptx" />

<!-- Logarithmic growth/decay (i.e., accumulation when rate of variation is 1/x.) Logarithm function: graph, properties, etc. -->
<xi:include href="./log.ptx" />

<!-- Logistic models, associated differential equations. -->
<xi:include href="./logistic.ptx" />

<!-- Exponential growth/decay. Exponential function: graph, properties, etc. -->
<xi:include href="./exp.ptx" />

<!-- Accumulation when rate of variation is exponential. Separable differential equations. -->
<xi:include href="./separable.ptx" />

<!-- Periodic growth/decay. Trig functions: graphs, properties, etc. -->
<xi:include href="./periodic.ptx" />

<!-- Models & differential equations where solution is periodic, with examples from the sciences. -->
<xi:include href="./pmodels.ptx" />

<!-- Average rate of variation. Differentials and approximate rate of variation. -->
<xi:include href="./avg-rate.ptx" />

<!--
  Exact rate of variation from approximate rate of variation.
  Rate of variation formulas (polynomial, logarithmic, exponential, trig).
-->
<xi:include href="./instant-rate.ptx" />

<!--
  Implicit differentiation.
  One-to-one and inverse functions.
  Rate of variation for inverse functions.
-->
<xi:include href="./imp-inv.ptx" />

<!-- Average value of a function. Mean Value Theorems. Fundamental Theorem. -->
<xi:include href="./fund-thm.ptx" />

<!-- Chain rule. Reversing the chain rule (substitution). -->
<xi:include href="./chain.ptx" />

<!-- Product rule. Linear differential equations and integrating factors. -->
<xi:include href="./product.ptx" />

<!-- Higher-order rate functions. Curve-sketching. -->
<xi:include href="./higher.ptx" />

<!-- Local/absolute extremes. Optimization. -->
<xi:include href="./opt.ptx" />

<!-- Autonomous differential equations. -->
<xi:include href="./auto.ptx" />

<!-- -->
<xi:include href="./backmatter.ptx" />

</book>

</pretext>
